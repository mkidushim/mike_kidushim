---
interface Service {
  title: string;
  description: string;
}

const services: Service[] = [
  {
    title: "MVP Build",
    description: "From idea to launch, fully functional"
  },
  {
    title: "Legacy System Modernization",
    description: "Migrate outdated systems to modern tech stacks"
  },
  {
    title: "Internal Dashboards",
    description: "Admin portals, analytics, reporting"
  },
  {
    title: "Backend APIs",
    description: "Integrations, automation, scaling"
  },
  {
    title: "Full-Stack Web Applications",
    description: "End-to-end development with modern frameworks"
  },
  {
    title: "System Architecture & Consulting",
    description: "Technical guidance, scalability planning, tech decisions"
  },
  {
    title: "Performance Optimization",
    description: "Speed improvements, database optimization, refactoring"
  },
  {
    title: "Maintenance & Support",
    description: "Ongoing updates & feature development"
  }
];
---

<section id="services" class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    {/* Header */}
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Services
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
        Tailored solutions built by a senior full-stack engineer with 10+ years of experience. Custom pricing based on scope and complexity.
      </p>
    </div>

    {/* Services Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 service-grid">
      {services.map((service, index) => (
        <div
          class="group relative bg-white border border-gray-200 rounded-xl p-8 hover:border-blue-400 hover:shadow-xl transition-all duration-300 overflow-hidden"
        >
          {/* Background accent */}
          <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50 rounded-full -mr-12 -mt-12 group-hover:bg-blue-100 transition-colors duration-300"></div>

          {/* Service Title */}
          <div class="relative z-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors duration-300">
              {service.title}
            </h3>

            {/* Service Description */}
            <p class="text-gray-600 text-lg leading-relaxed mb-8">
              {service.description}
            </p>


            {/* CTA Link */}
            <div class="mt-8 pt-6 border-t border-gray-200 group-hover:border-blue-200 transition-colors duration-300">
              <a
                href="#contact"
                class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700 transition-colors duration-200"
              >
                Learn more
                <svg
                  class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 7l5 5m0 0l-5 5m5-5H6"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Bottom CTA */}
    <div class="mt-16 text-center">
      <p class="text-gray-600 text-lg mb-6">
        Not sure which service is right for you?
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-3 bg-blue-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-blue-700 transition-colors duration-300 shadow-lg hover:shadow-xl"
      >
        Schedule a consultation
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"
          />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Smooth transitions for interactive elements */
  :global {
    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  }

  /* Center items when fewer than 3 columns on large screens */
  @media (min-width: 1024px) {
    .service-grid {
      justify-content: center;
    }

    .service-grid > div {
      width: 24rem;
    }
  }
</style>

